# ─── 콘텐츠 생성 모드 ───
# rss = RSS 자동 수집 | gems = 사용자 주제 + Gems 프롬프트
CONTENT_MODE=gems

# gems 모드: 기본 주제 (npm run run:once 실행 시 Enter로 사용 가능)
# 키워드만 넣어도 됩니다. 예: E-7-4R, 비자변경, 행정사
# BLOG_TOPIC=

# 같은 주제를 AI로 다시 생성하려면 true
FORCE_REGENERATE=false

# published 상태 주제도 기존 원고로 퍼블리싱만 재시도
RETRY_PUBLISH=false

# 썸네일 — 디자인은 assets/thumbnail/brand.json 고정, 문구만 매번 변경
# THUMBNAIL_SHOW_SUBTITLE=false

# 본문 이미지 — assets/images/02.png~09.png + config/image-manifest.json

# ─── LLM API 설정 ───
# Gems 프롬프트(작성 규칙)와 API는 별개입니다.
# Gems 지시문 + OpenAI API 조합을 권장합니다.
LLM_PROVIDER=openai

# OpenAI (권장)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Gemini API (LLM_PROVIDER=gemini 일 때만 필요)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Gems 작성 규칙 파일 (Gemini API 불필요, 프롬프트 텍스트만 사용)
# GEMINI_GEMS_PROMPT_PATH=prompts/gems-system.prompt.md

# RSS 피드 (CONTENT_MODE=rss 일 때만 사용)
# RSS_FEED_URLS=https://example.com/feed.xml

# ─── Discord 알림 ───
DISCORD_WEBHOOK_URL=

# ─── 퍼블리싱 ───
PUBLISH_DRY_RUN=true
PUBLISH_HEADLESS=false
PUBLISH_SKIP_THUMBNAIL=false

# ─── 스케줄러 ───
CRON_SCHEDULE=0 9 * * *
CRON_TIMEZONE=Asia/Seoul
RUN_ON_START=false

# ─── 블로그 식별자 ───
NAVER_BLOG_ID=
TISTORY_BLOG_NAME=

# ─── 자동 로그인 (세션 만료 시 .env 계정으로 자동 재로그인) ───
AUTH_AUTO_LOGIN=true
# 자동 로그인 시 브라우저 숨김 (봇 차단 시 false 권장 — 기본은 창 표시)
# AUTH_LOGIN_HEADLESS=false

NAVER_ID=
NAVER_PASSWORD=

# 티스토리는 카카오 계정으로 로그인
KAKAO_ID=
KAKAO_PASSWORD=

# ─── 웹 서버 (Docker/로컬) ───
PORT=3000
API_KEY=
ENABLE_WEB_SCHEDULER=true

# Vercel 배포
# true이면 대시보드 API_KEY 인증 비활성화 (vercel.json에 기본 설정됨)
DISABLE_API_AUTH=true
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
# Vercel Cron 보안 (Vercel이 자동 주입, 로컬 테스트용)
CRON_SECRET=
