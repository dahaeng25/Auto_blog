# OpenAI (Phase 2)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# RSS 피드 URL (쉼표 구분, 비우면 기본 피드 사용)
# RSS_FEED_URLS=https://example.com/feed.xml,https://other.com/rss

# Discord Webhook (Phase 5)
DISCORD_WEBHOOK_URL=

# Phase 4 퍼블리싱
PUBLISH_DRY_RUN=true
PUBLISH_HEADLESS=false

# Phase 5 스케줄러 (매일 09:00 KST)
CRON_SCHEDULE=0 9 * * *
CRON_TIMEZONE=Asia/Seoul
RUN_ON_START=false

# 블로그 식별자 (Phase 4에서 사용)
NAVER_BLOG_ID=
TISTORY_BLOG_NAME=

# 웹 서버 (Docker/로컬)
PORT=3000
API_KEY=
ENABLE_WEB_SCHEDULER=true

# Vercel 배포
# true이면 API_KEY 로그인 화면 비활성화 (Vercel vercel.json에 기본 설정됨)
DISABLE_API_AUTH=true
# 로컬에서도 로그인 생략 시
AUTH_AUTO_LOGIN=true
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
# Vercel Cron 보안 (Vercel이 자동 주입, 로컬 테스트용)
CRON_SECRET=
