# ─── 콘텐츠 생성 모드 ───
# rss = RSS 자동 수집 | gems = 사용자 주제 + Gems 프롬프트
CONTENT_MODE=gems

# gems 모드: 기본 주제 (npm run run:once 실행 시 Enter로 사용 가능)
# 키워드만 넣어도 됩니다. 예: E-7-4R, 비자변경, 행정사
# BLOG_TOPIC=

# gems 모드: 상위 지역 (도·광역시). blog-region.txt 보다 CLI --region 우선
# BLOG_REGION=전라북도

# 같은 주제를 AI로 다시 생성하려면 true
FORCE_REGENERATE=false

# published 상태 주제도 기존 원고로 퍼블리싱만 재시도
RETRY_PUBLISH=false

# 썸네일 — blue_directors 샘플 프레임 + 키워드별 AI 배경 + 가운데 문구만 변경
# THUMBNAIL_SHOW_SUBTITLE=false
# THUMBNAIL_DYNAMIC_BG=true
# THUMBNAIL_BG_MODEL=gpt-image-1
# 서브썸네일 — 그라데이션 + 중앙 키워드 (기본). AI 배경 쓰려면 true
# SUB_THUMBNAIL_DYNAMIC_BG=false
# SUB_THUMBNAIL_CONTACT_NAME=강운준 행정사
# SUB_THUMBNAIL_CONTACT_PHONE=1844-1346
# 서브썸네일 AI 배경 동시 생성 수 (SUB_THUMBNAIL_DYNAMIC_BG=true 일 때)
# SUB_THUMBNAIL_BG_CONCURRENCY=3

# 네이버 — blue_directors 샘플 스타일·이미지 + 키워드 파일명(1~)·메타태그 자동 적용 (기본 true)
# NAVER_USE_SAMPLE_STYLE=true

# 네이버 본문 맨 끝 푸터 (지도·이미지·HTML 템플릿) — config/naver-post-footer.json
# NAVER_POST_FOOTER_ENABLED=true
# NAVER_POST_FOOTER_PATH=config/naver-post-footer.json

# 본문 이미지 — assets/images/02.png~09.png + config/image-manifest.json

# ─── LLM API 설정 ───
# Gems 프롬프트(작성 규칙)와 API는 별개입니다.
# - openai + gpt-4o: 안정적 JSON 출력 (현재 기본)
# - gemini + gemini-2.0-flash: Gemini Gems에서 쓰던 모델에 가깝게
LLM_PROVIDER=openai

# OpenAI (권장)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Gemini API (LLM_PROVIDER=gemini 일 때만 필요)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Gems 작성 규칙 파일 (Gemini API 불필요, 프롬프트 텍스트만 사용)
# GEMINI_GEMS_PROMPT_PATH=prompts/gems-system.prompt.md

# PDF 지식 베이스 (Gems 모드 — PDF에서 관련 구간 검색·주입)
# 상대 경로: 프로젝트 knowledge/ | 절대 경로: Google Drive 로컬 동기화 폴더 등
# KNOWLEDGE_DIR=knowledge
# KNOWLEDGE_DIR=G:\My Drive\출입국
# KNOWLEDGE_ENABLED=true
# KNOWLEDGE_MAX_CHUNKS=5

# RSS 피드 (CONTENT_MODE=rss 일 때만 사용)
# RSS_FEED_URLS=https://example.com/feed.xml

# ─── Discord 알림 ───
# 발행 성공/실패 시 Webhook으로 제목·URL·에러 단계 전송
DISCORD_WEBHOOK_URL=

# ─── 퍼블리싱 ───
PUBLISH_DRY_RUN=true
PUBLISH_HEADLESS=false
PUBLISH_SKIP_THUMBNAIL=false

# ─── 스케줄러 ───
CRON_SCHEDULE=0 9 * * *
CRON_TIMEZONE=Asia/Seoul
RUN_ON_START=false

# ─── 블로그 식별자 ───
NAVER_BLOG_ID=
TISTORY_BLOG_NAME=
BLOGGER_BLOG_ID=

# ─── 발행 플랫폼 on/off (Docker 권장) ───
ENABLE_NAVER_PUBLISH=true
ENABLE_TISTORY_PUBLISH=true
ENABLE_GOOGLE_PUBLISH=false

# ─── 자동 로그인 (세션 만료 시 .env 계정으로 자동 재로그인) ───
AUTH_AUTO_LOGIN=true
# 자동 로그인 시 브라우저 숨김 (봇 차단 시 false 권장 — 기본은 창 표시)
# AUTH_LOGIN_HEADLESS=false

NAVER_ID=
NAVER_PASSWORD=

# 티스토리는 카카오 계정으로 로그인
KAKAO_ID=
KAKAO_PASSWORD=

# ─── 웹 서버 (Docker/로컬) ───
PORT=3000
DEPLOYMENT_MODE=local
ENABLE_WEB_SCHEDULER=true
# 로컬/Docker는 SQLite 기본. Vercel용 Turso를 쓰려면 USE_TURSO=true
# USE_TURSO=false
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
# Vercel Cron 보안 (Vercel이 자동 주입, 로컬 테스트용)
CRON_SECRET=
