# OpenAI (Phase 2)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# RSS 피드 URL (쉼표 구분, 비우면 기본 피드 사용)
# RSS_FEED_URLS=https://example.com/feed.xml,https://other.com/rss

# Discord Webhook (Phase 5)
DISCORD_WEBHOOK_URL=

# Phase 4 퍼블리싱
PUBLISH_DRY_RUN=true
PUBLISH_HEADLESS=false

# Phase 5 스케줄러 (매일 09:00 KST)
CRON_SCHEDULE=0 9 * * *
CRON_TIMEZONE=Asia/Seoul
RUN_ON_START=false

# 블로그 식별자 (Phase 4에서 사용)
NAVER_BLOG_ID=
TISTORY_BLOG_NAME=
