    "@sparticuz/chromium": "^149.0.0",
    "@vercel/node": "^5.1.14",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "node-cron": "^3.0.3",
    "openai": "^4.87.3",
    "pdf-parse": "^1.1.1",
    "playwright": "^1.50.1",
    "playwright-core": "^1.50.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-core": "^24.43.1",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "rss-parser": "^3.13.0",
    "sharp": "^0.35.2"
  },
