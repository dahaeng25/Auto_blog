{
  "name": "blog-orchestrator",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "setup": "node setup.mjs",
    "setup:full": "node setup.mjs --full --wizard",
    "auth:setup": "tsx scripts/setup-auth.ts",
    "content:test": "tsx scripts/test-content.ts",
    "thumbnail:test": "tsx scripts/test-thumbnail.ts",
    "publish:test": "tsx scripts/test-publish.ts",
    "run:once": "tsx scripts/run-once.ts",
    "build": "tsc --noEmit",
    "web": "tsx src/server.ts",
    "start": "tsx src/server.ts",
    "start:cli": "tsx src/index.ts"
  },
  "dependencies": {
    "@fastify/static": "^8.1.1",
    "@sparticuz/chromium": "^131.0.1",
    "@vercel/node": "^5.1.14",
