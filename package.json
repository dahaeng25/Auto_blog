    "fastify": "^5.2.1",
    "node-cron": "^3.0.3",
    "openai": "^4.87.3",
    "playwright": "^1.50.1",
    "playwright-core": "^1.50.1",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node-cron": "^3.0.11",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "optionalDependencies": {
    "@libsql/client": "^0.14.0",
    "better-sqlite3": "^11.8.1"
