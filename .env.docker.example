# ─── Docker 전용 예시 (.env 로 복사) ───
# cp .env.docker.example .env

DEPLOYMENT_MODE=docker

# ─── 콘텐츠 ───
CONTENT_MODE=gems
BLOG_TOPIC=행정사 법무사의 미래
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ─── 발행 플랫폼 (false 로 끄기) ───
ENABLE_NAVER_PUBLISH=true
ENABLE_TISTORY_PUBLISH=true
ENABLE_GOOGLE_PUBLISH=true

# ─── 블로그 식별자 ───
NAVER_BLOG_ID=
TISTORY_BLOG_NAME=
# Blogger 설정 → 기본 페이지 URL의 숫자 ID
BLOGGER_BLOG_ID=

# ─── 퍼블리싱 ───
PUBLISH_DRY_RUN=true
PUBLISH_HEADLESS=true
PUBLISH_SKIP_THUMBNAIL=false

# ─── 스케줄러 (Docker에서 매일 자동 실행) ───
ENABLE_WEB_SCHEDULER=true
CRON_SCHEDULE=0 9 * * *
CRON_TIMEZONE=Asia/Seoul
RUN_ON_START=false

# ─── 자동 로그인 (선택, Google은 미지원) ───
AUTH_AUTO_LOGIN=true
NAVER_ID=
NAVER_PASSWORD=
KAKAO_ID=
KAKAO_PASSWORD=

# ─── 알림 (선택) ───
DISCORD_WEBHOOK_URL=

PORT=3000

# Docker에서는 Turso 불필요 — 로컬 SQLite (./data/blog.db) 사용
# USE_TURSO=true
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=
