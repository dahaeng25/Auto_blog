{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "framework": null,
  "functions": {
    "api/proxy.ts": {
      "maxDuration": 30
    },
    "api/run.ts": {
      "maxDuration": 300,
      "includeFiles": "{assets/thumbnail/**,src/thumbnail/**,assets/images/**,config/blog-style.json,config/image-manifest.json,node_modules/@sparticuz/chromium/**,node_modules/puppeteer-core/**}"
    },
    "api/run/step.ts": {
      "maxDuration": 300,
      "includeFiles": "{assets/thumbnail/**,src/thumbnail/**,assets/images/**,config/blog-style.json,config/image-manifest.json,node_modules/@sparticuz/chromium/**,node_modules/puppeteer-core/**}"
    },
    "api/cron.ts": {
      "maxDuration": 300,
      "includeFiles": "{assets/thumbnail/**,src/thumbnail/**,assets/images/**,config/blog-style.json,config/image-manifest.json,node_modules/@sparticuz/chromium/**,node_modules/puppeteer-core/**}"
    },
    "api/sessions/[platform].ts": {
      "maxDuration": 30
    },
    "api/sessions/[platform]/refresh.ts": {
      "maxDuration": 300,
      "includeFiles": "{node_modules/@sparticuz/chromium/**,node_modules/puppeteer-core/**}"
    },
    "api/dashboard.ts": {
      "maxDuration": 10,
      "includeFiles": "public/index.html"
    },
    "api/files/[name].ts": {
      "maxDuration": 10,
      "includeFiles": "public/{dashboard.js,styles.css,index.html}"
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/api/dashboard" },
    { "source": "/dashboard.js", "destination": "/api/files/dashboard.js" },
    { "source": "/styles.css", "destination": "/api/files/styles.css" },
    { "source": "/app.js", "destination": "/api/files/dashboard.js" },
    {
      "source": "/api/:path*",
      "destination": "/api/proxy?p=:path*"
    }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 0 * * *"
    }
  ],
  "env": {
    "PUBLISH_HEADLESS": "true",
    "USE_SERVERLESS_CHROMIUM": "true",
    "ENABLE_WEB_SCHEDULER": "false",
    "AWS_LAMBDA_JS_RUNTIME": "nodejs22.x"
  },
  "headers": [
    {
      "source": "/(.*)\\.(js|css|html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "CDN-Cache-Control", "value": "no-store" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/api/(dashboard|files)/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "CDN-Cache-Control", "value": "no-store" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
